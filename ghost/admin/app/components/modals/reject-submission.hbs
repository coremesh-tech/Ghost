<div class="modal-content" data-test-modal="reject-submission">
    <header class="modal-header">
        <h1>Reject Submission</h1>
    </header>
    <button class="close" title="Close" type="button" {{on "click" (fn @close null)}}>
        {{svg-jar "close"}}<span class="hidden">Close</span>
    </button>

    <div class="modal-body">
        <p>Please enter a reason for rejecting the submission (required):</p>
        <div class="form-group">
            <textarea
                class="gh-input"
                style="resize: none; margin-top: 10px;min-height: 200px;"
                placeholder="Review comment..."
                value={{this.reviewComment}}
                maxlength="512"
                {{on "input" this.updateReviewComment}}
                autofocus
            ></textarea>
        </div>
    </div>

    <div class="modal-footer">
        <button class="gh-btn" data-test-button="cancel-reject" type="button" {{on "click" (fn @close null)}}>
            <span>Cancel</span>
        </button>
        <button
            class="gh-btn gh-btn-red"
            data-test-button="confirm-reject"
            type="button"
            disabled={{this.confirmDisabled}}
            {{on "click" this.confirm}}
        >
            <span>Confirm Reject</span>
        </button>
    </div>
</div>
